# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Required: long random string to sign session cookies.
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace-with-a-long-random-string

# Optional: emails that are auto-promoted to admin when they register.
ADMIN_EMAILS=you@yourcompany.com

# Optional: enables AI-assisted parsing. Can also be set in the app Settings page.
OPENAI_API_KEY=sk-...
